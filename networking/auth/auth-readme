YAML
# app-deploy.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: secure-app-deploy
spec:
  replicas: 3 # ◄─ Scaled to 3 to support testing session stickiness
  selector:
    matchLabels:
      app: secure-app
  template:
    metadata:
      labels:
        app: secure-app
    spec:
      containers:
      - name: http-echo
        image: hashicorp/http-echo
        args: ["-text=Welcome to the Secret Vault !!", "-listen=:80"]
        ports:
        - containerPort: 80
---
apiVersion: v1
kind: Service
metadata:
  name: secure-app-svc
spec:
  ports:
  - port: 80
    targetPort: 80
  selector:
    app: secure-app
---
# ingress-secure.yaml
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: secure-app-ingress
  annotations:
    # ─── BASIC AUTH CONFIGURATION ACTIVATED ──────────────────────────
    nginx.ingress.kubernetes.io/auth-type: "basic"
    nginx.ingress.kubernetes.io/auth-secret: "secure-app-auth"
    nginx.ingress.kubernetes.io/auth-realm: "Authentication Required - Secure Vault"

    # ─── SESSION STICKINESS CONFIGURATION ────────────────────────────
    nginx.ingress.kubernetes.io/affinity: "cookie"
    nginx.ingress.kubernetes.io/session-cookie-name: "route-cookie"
    nginx.ingress.kubernetes.io/affinity-mode: "balanced"
    nginx.ingress.kubernetes.io/session-cookie-expires: "300" # ◄─ 5 minutes lifespan
    nginx.ingress.kubernetes.io/session-cookie-path: "/"       # ◄─ Correct application URL scope
spec:
  ingressClassName: nginx # ◄─ Replaces the deprecated kubernetes.io/ingress.class annotation
  tls:
  - hosts:
    - secure-app.com
    secretName: my-app-tls-secret # ◄─ Matches the secret name you created earlier
  rules:
  - host: secure-app.com
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: secure-app-svc
            port:
              number: 80
