# 1. Create the initial deployments
kubectl create deployment app1 --image=hashicorp/http-echo
kubectl create deployment app2 --image=hashicorp/http-echo

# 2. Patch deployments with correct JSON syntax and set listen ports to 80
kubectl patch deployments.apps app1 -p '{"spec":{"template":{"spec":{"containers":[{"name":"http-echo","args":["-text=Hello from app1 !! app1 loaded successfully","-listen=:80"]}]}}}}'
kubectl patch deployments.apps app2 -p '{"spec":{"template":{"spec":{"containers":[{"name":"http-echo","args":["-text=Hello from app2 !! app2 loaded successfully","-listen=:80"]}]}}}}'

# 3. Expose deployments as services targeting the correct application port (80)
kubectl expose deployment app1 --port=80 --target-port=80 --name=app1-svc
kubectl expose deployment app2 --port=80 --target-port=80 --name=app2-svc

# 4. Create the Ingress resource with routing rules for both applications
kubectl create ingress my-nginx-ingress --class=nginx --rule="my-host.com/app1=app1-svc:80" --rule="my-host.com/app2=app2-svc:80"

# 5. Map the domain name to the master node IP inside the local hosts file
echo "192.168.31.157 my-host.com" | sudo tee -a /etc/hosts

# 6. Verify and test the traffic routing through the ingress nodeport
# (Replace 30985 with whatever your active ingress-nginx-controller NodePort is)
curl http://my-host.com:30985/app1
curl http://my-host.com:30985/app2
